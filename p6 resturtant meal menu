 7.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int meal;
    cout << "Enter meal code: "; 
    cin >> meal;

    // The switch evaluates the 'meal' variable
    switch (meal) {
        case 1: 
            cout << "Breakfast" << endl; 
            break; // Exits the switch block immediately

        case 2: 
            cout << "Lunch" << endl; 
            break;

        case 3: 
            cout << "Dinner" << endl; 
            break;

        default: 
            // Runs automatically if 'meal' is any number other than 1, 2, or 3
            cout << "Invalid meal code!" << endl;
            break;
    }

    return 0;
}
