 7.3 IF-ELSE-IF 
#include <iostream>
using namespace std;

int main() {
    int meal;
    cout << "Enter meal code: "; 
    cin >> meal;

    // 1. First check
    if (meal == 1) {
        cout << "Breakfast" << endl;
    } 
    // 2. Second check (only runs if meal wasn't 1)
    else if (meal == 2) {
        cout << "Lunch" << endl;
    } 
    // 3. Third check (only runs if meal wasn't 1 or 2)
    else if (meal == 3) {
        cout << "Dinner" << endl;
    } 
    // 4. Safety fallback (runs if none of the explicit options matched)
    else {
        cout << "Invalid meal code!" << endl;
    }

    return 0;
}
