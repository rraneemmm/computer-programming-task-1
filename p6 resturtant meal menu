#include <iostream>
using namespace std;

int main() {
    int meal;
    cout << "Enter meal code: "; cin >> meal;

    // Outer IF: Validates that the input code belongs to a valid meal option (1, 2, or 3)
    if (meal >= 1 && meal <= 3) {
        
        // Inner IF-ELSE-IF: Delivers specific menu text once input is validated
        if (meal == 1) {
            cout << "Breakfast - pancakes await!" << endl;
        } else if (meal == 2) {
            cout << "Lunch - sandwiches served!" << endl;
        } else { // Must be 3 since it passed the outer filter and isn't 1 or 2
            cout << "Dinner - candlelight ready!" << endl;
        }

    } else {
        // Runs immediately if the user inputs something outside the 1 to 3 options
        cout << "Invalid meal code!" << endl;
    }

    return 0;
}
