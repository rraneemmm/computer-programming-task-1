Statement: Codes: 1 = Red, 2 = Yellow, 3 = Green. Print the driver's action.

1. if*

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter light code: "; cin >> code;
    if (code == 1)
        cout << "STOP immediately." << endl;
    cout << "Signal processed." << endl;
    return 0;
}


2. if-else*

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter light code: "; cin >> code;
    if (code >= 1 && code <= 3)
        cout << "Valid signal." << endl;
    else
        cout << "Invalid signal." << endl;
    return 0;
}


3. if-else-if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter light code: "; cin >> code;
    if (code == 1)
        cout << "STOP" << endl;
    else if (code == 2)
        cout << "GET READY" << endl;
    else if (code == 3)
        cout << "GO" << endl;
    else
        cout << "Invalid signal." << endl;
    return 0;
}


4. switch

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter light code: "; cin >> code;
    switch (code) {
        case 1: cout << "STOP" << endl; break;
        case 2: cout << "GET READY" << endl; break;
        case 3: cout << "GO" << endl; break;
        default: cout << "Invalid signal." << endl;
    }
    return 0;
}



5. Nested if


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter light code: "; cin >> code;
    if (code >= 1 && code <= 3) {
        if (code == 1)
            cout << "STOP" << endl;
        else {
            if (code == 2)
                cout << "GET READY" << endl;
            else
                cout << "GO" << endl;
        }
    } else
        cout << "Invalid signal." << endl;
    return 0;
}
