/ 10.5 NESTED IF 
#include <iostream>
using namespace std;

int main() {
    int level;
    cout << "Enter fitness level code: "; cin >> level;

    // Outer IF: Restricts execution to valid choices (1, 2, or 3)
    if (level >= 1 && level <= 3) {
        
        // Inner IF-ELSE: Drills down to find the specific fitness level
        if (level == 1) {
            cout << "Beginner" << endl;
        } else if (level == 2) {
            cout << "Intermediate" << endl;
        } else { // Must be 3 because it passed the outer filter and isn't 1 or 2
            cout << "Advanced" << endl;
        }

    } else {
        // Fallback for any invalid out-of-range inputs
        cout << "Invalid fitness level code!" << endl;
    }

    return 0;
}
