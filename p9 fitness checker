 10.2 IF-ELSE 
#include <iostream>
using namespace std;

int main() {
    int level;
    cout << "Enter fitness level code: "; 
    cin >> level;

    // Checks the first condition
    if (level == 1) {
        cout << "Beginner - start slow, you got this!" << endl;
    } 
    else {
        // This runs automatically for ANY number that is not 1
        cout << "Not a beginner - keep pushing!" << endl;
    }

    return 0;
}
 10.3 IF-ELSE-IF 
#include <iostream>
using namespace std;

int main() {
    int level;
    cout << "Enter fitness level code: "; 
    cin >> level;

    // 1. First check
    if (level == 1) {
        cout << "Beginner" << endl;
    } 
    // 2. Second check (only runs if level wasn't 1)
    else if (level == 2) {
        cout << "Intermediate" << endl;
    } 
    // 3. Third check (only runs if level wasn't 1 or 2)
    else if (level == 3) {
        cout << "Advanced" << endl;
    } 
    // 4. Safety fallback (runs if none of the numbers above matched)
    else {
        cout << "Invalid fitness level code!" << endl;
    }

    return 0;
}
 10.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int level;
    cout << "Enter fitness level code: "; 
    cin >> level;

    // The switch evaluates the 'level' variable
    switch (level) {
        case 1: 
            cout << "Beginner" << endl; 
            break; // Exits the switch block immediately

        case 2: 
            cout << "Intermediate" << endl; 
            break;

        case 3: 
            cout << "Advanced" << endl; 
            break;

        default: 
            // Runs automatically if 'level' is any number other than 1, 2, or 3
            cout << "Invalid fitness level code!" << endl;
            break;
    }

    return 0;
}
