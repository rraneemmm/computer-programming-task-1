Statement: Codes: 1 = Winter, 2 = Spring, 3 = Summer, 4 = Autumn.

1. if


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter season code: "; cin >> code;
    if (code == 3)
        cout << "Summer - stay hydrated!" << endl;
    cout << "Season processed." << endl;
    return 0;
}



2. if-else


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter season code: "; cin >> code;
    if (code >= 1 && code <= 4)
        cout << "Valid season." << endl;
    else
        cout << "Invalid season." << endl;
    return 0;
}



3. if-else-if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter season code: "; cin >> code;
    if (code == 1) cout << "Winter" << endl;
    else if (code == 2) cout << "Spring" << endl;
    else if (code == 3) cout << "Summer" << endl;
    else if (code == 4) cout << "Autumn" << endl;
    else cout << "Invalid season." << endl;
    return 0;
}



4. switch


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter season code: "; cin >> code;
    switch (code) {
        case 1: cout << "Winter" << endl; break;
        case 2: cout << "Spring" << endl; break;
        case 3: cout << "Summer" << endl; break;
        case 4: cout << "Autumn" << endl; break;
        default: cout << "Invalid season." << endl;
    }
    return 0;
}



5. Nested if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter season code: "; cin >> code;
    if (code >= 1 && code <= 4) {
        if (code <= 2) {
            if (code == 1) cout << "Winter" << endl;
            else cout << "Spring" << endl;
        } else {
            if (code == 3) cout << "Summer" << endl;
            else cout << "Autumn" << endl;
        }
    } else
        cout << "Invalid season." << endl;
    return 0;
}
