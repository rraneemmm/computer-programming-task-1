Statement: Codes 1-7 represent Monday-Sunday. Print the day name.

1. if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter day code (1-7): "; cin >> code;
    if (code == 7)
        cout << "It's Sunday - rest day!" << endl;
    cout << "Day processed." << endl;
    return 0;
}


2. if-else

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter day code (1-7): "; cin >> code;
    if (code >= 1 && code <= 7)
        cout << "Valid day code." << endl;
    else
        cout << "Invalid day code." << endl;
    return 0;
}


3. if-else-if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter day code (1-7): "; cin >> code;
    if (code == 1) cout << "Monday" << endl;
    else if (code == 2) cout << "Tuesday" << endl;
    else if (code == 3) cout << "Wednesday" << endl;
    else if (code == 4) cout << "Thursday" << endl;
    else if (code == 5) cout << "Friday" << endl;
    else if (code == 6) cout << "Saturday" << endl;
    else if (code == 7) cout << "Sunday" << endl;
    else cout << "Invalid day code." << endl;
    return 0;
}


4. switch

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter day code (1-7): "; cin >> code;
    switch (code) {
        case 1: cout << "Monday" << endl; break;
        case 2: cout << "Tuesday" << endl; break;
        case 3: cout << "Wednesday" << endl; break;
        case 4: cout << "Thursday" << endl; break;
        case 5: cout << "Friday" << endl; break;
        case 6: cout << "Saturday" << endl; break;
        case 7: cout << "Sunday" << endl; break;
        default: cout << "Invalid day code." << endl;
    }
    return 0;
}

5. Nested if


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter day code (1-7): "; cin >> code;
    if (code >= 1 && code <= 7) {
        if (code <= 5)
            cout << "Weekday" << endl;
        else {
            if (code == 6)
                cout << "Saturday (Weekend)" << endl;
            else
                cout << "Sunday (Weekend)" << endl;
        }
    } else
        cout << "Invalid day code." << endl;
    return 0;
}
