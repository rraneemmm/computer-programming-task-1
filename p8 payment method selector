 9.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int method;
    cout << "Enter payment code: "; 
    cin >> method;

    // The switch evaluates the 'method' variable
    switch (method) {
        case 1: 
            cout << "Cash" << endl; 
            break; // Exits the switch block immediately

        case 2: 
            cout << "Card" << endl; 
            break;

        case 3: 
            cout << "Online" << endl; 
            break;

        default: 
            // Runs automatically if 'method' is any number other than 1, 2, or 3
            cout << "Invalid payment code!" << endl;
            break;
    }

    return 0;
}
