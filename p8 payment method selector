 9.5 NESTED IF 
#include <iostream>
using namespace std;

int main() {
    int method;
    cout << "Enter payment code: "; cin >> method;

    // Outer IF: Checks if the code is within the valid range (1 to 3)
    if (method >= 1 && method <= 3) {
        
        // Inner IF-ELSE: Digs down to identify the exact method
        if (method == 1) {
            cout << "Cash" << endl;
        } else if (method == 2) {
            cout << "Card" << endl;
        } else { // Must be 3 since it passed the outer filter and isn't 1 or 2
            cout << "Online" << endl;
        }

    } else {
        // Runs immediately if the user inputs any other number
        cout << "Invalid payment code!" << endl;
    }

    return 0;
}
