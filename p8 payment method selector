 9.3 IF-ELSE-IF 
#include <iostream>
using namespace std;

int main() {
    int method;
    cout << "Enter payment code: "; 
    cin >> method;

    // 1. First check
    if (method == 1) {
        cout << "Cash" << endl;
    } 
    // 2. Second check (only runs if method wasn't 1)
    else if (method == 2) {
        cout << "Card" << endl;
    } 
    // 3. Third check (only runs if method wasn't 1 or 2)
    else if (method == 3) {
        cout << "Online" << endl;
    } 
    // 4. Safety fallback (runs if none of the numbers above matched)
    else {
        cout << "Invalid payment code!" << endl;
    }

    return 0;
}
