#include <iostream>
using namespace std;
int main() {
    int day;
    cout << "Enter day type code: "; cin >> day;
    
    // Outer IF: Filters out completely invalid numbers first
    if (day == 1 || day == 2) {
        
        // Inner IF-ELSE: Decides the day type once we know it's valid
        if (day == 1) {
            cout << "Weekday - work mode!" << endl;
        } else {
            cout << "Weekend - rest mode!" << endl;
        }
        
    } else {
        cout << "Invalid day type!" << endl;
    }
    
