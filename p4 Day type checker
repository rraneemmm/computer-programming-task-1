 3.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int day;
    cout << "Enter day type code: "; 
    cin >> day;

    // The switch structure evaluates the 'day' variable
    switch (day) {
        case 1: 
            cout << "Weekday - work mode!" << endl; 
            break; // Stops the code from spilling into the next case

        case 2: 
            cout << "Weekend - rest mode!" << endl; 
            break;

        default: 
            // Runs automatically if 'day' is anything other than 1 or 2
            cout << "Invalid day type!" << endl;
            break;
    }
