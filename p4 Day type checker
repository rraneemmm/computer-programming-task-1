3.2 IF-ELSE
#include <iostream>
using namespace std;

int main() {
    int day;
    cout << "Enter day type code: "; 
    cin >> day;

    // Checks the first condition
    if (day == 1) {
        cout << "Weekday - off to work!" << endl;
    } 
    else {
        // This runs automatically for ANY number that is not 1
        cout << "Weekend - off to rest!" << endl;
    }

    return 0;
}
 3.3 IF-ELSE-IF 
#include <iostream>
using namespace std;

int main() {
    int day;
    cout << "Enter day type code: "; 
    cin >> day;

    // 1. First explicit check
    if (day == 1) {
        cout << "Weekday - work mode!" << endl;
    } 
    // 2. Second explicit check (only evaluated if day wasn't 1)
    else if (day == 2) {
        cout << "Weekend - rest mode!" << endl;
    } 
    // 3. Safety net fallback (runs if the number wasn't 1 or 2)
    else {
        cout << "Invalid day type!" << endl;
    }

    return 0;
}
 
