int main() {
    int light;
    cout << "Enter light code: "; 
    cin >> light;

    // 1. First check
    if (light == 1) {
        cout << "RED - Stop!" << endl;
    } 
    // 2. Second check (only runs if the first one was false)
    else if (light == 2) {
        cout << "YELLOW - Slow down!" << endl;
    } 
    // 3. Third check (only runs if both 1 and 2 were false)
    else if (light == 3) {
        cout << "GREEN - Go!" << endl;
    } 
    // 4. The final fallback (runs if absolutely nothing else matched)
    else {
        cout << "Unknown signal - flashing lights!" << endl;
    }

    return 0;
}
