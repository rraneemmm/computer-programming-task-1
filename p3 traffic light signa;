#include <iostream>
using namespace std;
int main() {
    int light;
    cout << "Enter light code: "; cin >> light;
    
    // Outer IF: Checks if the code is a valid signal number
    if (light >= 1 && light <= 3) {
        
        // Inner IFs: Runs only if the outer condition passes
        if (light == 1) {
            cout << "RED - Stop!" << endl;
        } else if (light == 2) {
            cout << "YELLOW - Slow down!" << endl;
        } else if (light == 3) {
            cout << "GREEN - Go!" << endl;
        }
        
    } else {
        // Runs if the code is completely invalid (e.g., 0 or 5)
        cout << "Unknown signal - flashing lights!" << endl;
    }
    
    return 0;
}
