#include <iostream>
using namespace std;

int main() {
    int light;
    cout << "Enter light code: "; 
    cin >> light;

    // The switch statement evaluates the variable 'light'
    switch (light) {
        case 1: 
            cout << "RED - Stop!" << endl; 
            break;
            
        case 2: 
            cout << "YELLOW - Slow down!" << endl; 
            break;
            
        case 3: 
            cout << "GREEN - Go!" << endl; 
            break;
            
        default: 
            // This catches any number that isn't 1, 2, or 3
            cout << "Unknown signal - flashing lights!" << endl;
            break;
    }

    return 0;
}
