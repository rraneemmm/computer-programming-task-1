Statement: Codes: 1 = Child ($5), 2 = Adult ($10), 3 = Senior ($7).

1. if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter ticket code: "; cin >> code;
    if (code == 3)
        cout << "Senior - discount applied!" << endl;
    cout << "Ticket processed." << endl;
    return 0;
}



2. if-else

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter ticket code: "; cin >> code;
    if (code >= 1 && code <= 3)
        cout << "Valid ticket code." << endl;
    else
        cout << "Invalid ticket code." << endl;
    return 0;
}



3. if-else-if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter ticket code: "; cin >> code;
    if (code == 1) cout << "Child - $5" << endl;
    else if (code == 2) cout << "Adult - $10" << endl;
    else if (code == 3) cout << "Senior - $7" << endl;
    else cout << "Invalid ticket code." << endl;
    return 0;
}


4. switch

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter ticket code: "; cin >> code;
    switch (code) {
        case 1: cout << "Child - $5" << endl; break;
        case 2: cout << "Adult - $10" << endl; break;
        case 3: cout << "Senior - $7" << endl; break;
        default: cout << "Invalid ticket code." << endl;
    }
    return 0;
}



5. Nested if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter ticket code: "; cin >> code;
    if (code >= 1 && code <= 3) {
        if (code == 1)
            cout << "Child - $5" << endl;
        else {
            if (code == 2)
                cout << "Adult - $10" << endl;
            else
                cout << "Senior - $7" << endl;
        }
    } else
        cout << "Invalid ticket code." << endl;
    return 0;
}

