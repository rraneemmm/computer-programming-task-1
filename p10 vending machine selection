 1.3 IF-ELSE-IF 
#include <iostream>
using namespace std;

int main() {
    int code;
    cout << "Enter code: "; 
    cin >> code;

    // 1. First check
    if (code == 1) {
        cout << "Water - $1" << endl;
    } 
    // 2. Second check (only runs if code wasn't 1)
    else if (code == 2) {
        cout << "Soda - $2" << endl;
    } 
    // 3. Third check (only runs if code wasn't 1 or 2)
    else if (code == 3) {
        cout << "Juice - $3" << endl;
    } 
    // 4. Safety fallback (runs if none of the numbers above matched)
    else {
        cout << "Invalid code - machine says beep!" << endl;
    }

    return 0;
}
1.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int code;
    cout << "Enter code: "; 
    cin >> code;

    // The switch evaluates the 'code' variable
    switch (code) {
        case 1: 
            cout << "Water - $1" << endl; 
            break; 

        case 2: 
            cout << "Soda - $2" << endl; 
            break;

        case 3: 
            cout << "Juice - $3" << endl; 
            break;

        default: 
    
            cout << "Invalid code - machine says beep!" << endl;
            break;
    }

    return 0;
}
