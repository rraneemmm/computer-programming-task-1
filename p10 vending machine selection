 1.5 NESTED IF 
#include <iostream>
using namespace std;

int main() {
    int code;
    cout << "Enter code: "; cin >> code;

    // Outer IF: Restricts execution to valid choices (1, 2, or 3)
    if (code >= 1 && code <= 3) {
        
        // Inner IF-ELSE: Drills down to find the specific item
        if (code == 1) {
            cout << "Water - $1" << endl;
        } else if (code == 2) {
            cout << "Soda - $2" << endl;
        } else { // Must be 3 because it passed the outer filter and isn't 1 or 2
            cout << "Juice - $3" << endl;
        }

    } else {
        // Fallback for any invalid out-of-range inputs
        cout << "Invalid code - machine says beep!" << endl;
    }

    return 0;
}
