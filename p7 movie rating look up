#include <iostream>
using namespace std;

int main() {
    int rating;
    cout << "Enter rating code: "; cin >> rating;

    // Outer IF: Validates that the input code belongs to a valid rating option (1 to 4)
    if (rating >= 1 && rating <= 4) {
        
        // Inner IF-ELSE-IF: Delivers specific rating details once range is verified
        if (rating == 1) {
            cout << "G - General Audience" << endl;
        } else if (rating == 2) {
            cout << "PG - Parental Guidance" << endl;
        } else if (rating == 3) {
            cout << "PG-13 - Parents Cautioned" << endl;
        } else { // Must be 4 since it passed the outer filter and isn't 1, 2, or 3
            cout << "R - Restricted" << endl;
        }

    } else {
        // Runs immediately if the user inputs something completely out-of-bounds
        cout << "Invalid rating code!" << endl;
    }

    return 0;
