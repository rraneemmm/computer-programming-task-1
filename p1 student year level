4.4 SWITCH 
#include <iostream>
using namespace std;

int main() {
    int year;
    cout << "Enter year code: "; 
    cin >> year;
    
    switch (year) {
        case 1: 
            cout << "Freshman" << endl; 
            break;
        case 2: 
            cout << "Sophomore" << endl; 
            break;
        case 3: 
            cout << "Junior" << endl; 
            break;
        case 4: 
            cout << "Senior" << endl; 
            break;
        default: 
            cout << "Invalid year code!" << endl;
    }
    
    return 0;
}
