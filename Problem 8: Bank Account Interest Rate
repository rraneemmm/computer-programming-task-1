Statement: Codes: 1 = Savings (4%), 2 = Current (1%), 3 = Fixed Deposit (6%).


1. if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter account code: "; cin >> code;
    if (code == 3)
        cout << "Fixed Deposit - best rate available!" << endl;
    cout << "Account processed." << endl;
    return 0;
}

2. if-else


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter account code: "; cin >> code;
    if (code >= 1 && code <= 3)
        cout << "Valid account code." << endl;
    else
        cout << "Invalid account code." << endl;
    return 0;
}



3. if-else-if


#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter account code: "; cin >> code;
    if (code == 1) cout << "Savings - 4% interest" << endl;
    else if (code == 2) cout << "Current - 1% interest" << endl;
    else if (code == 3) cout << "Fixed Deposit - 6% interest" << endl;
    else cout << "Invalid account code." << endl;
    return 0;
}



4. switch

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter account code: "; cin >> code;
    switch (code) {
        case 1: cout << "Savings - 4% interest" << endl; break;
        case 2: cout << "Current - 1% interest" << endl; break;
        case 3: cout << "Fixed Deposit - 6% interest" << endl; break;
        default: cout << "Invalid account code." << endl;
    }
    return 0;
}



5. Nested if

#include <iostream>
using namespace std;
int main() {
    int code;
    cout << "Enter account code: "; cin >> code;
    if (code >= 1 && code <= 3) {
        if (code == 1)
            cout << "Savings - 4% interest" << endl;
        else {
            if (code == 2)
                cout << "Current - 1% interest" << endl;
            else
                cout << "Fixed Deposit - 6% interest" << endl;
        }
    } else
        cout << "Invalid account code." << endl;
    return 0;
}

