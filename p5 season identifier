#include <iostream>
using namespace std;
int main() {
    int season;
    cout << "Enter season code: "; cin >> season;
    
    // Outer IF: Validates that the input is a valid season number (1, 2, 3, or 4)
    if (season >= 1 && season <= 4) {
        
        // Inner IF-ELSE-IF: Runs only if the number passed the range validation
        if (season == 1) {
            cout << "Winter - snowy days!" << endl;
        } else if (season == 2) {
            cout << "Spring - flowers bloom!" << endl;
        } else if (season == 3) {
            cout << "Summer - sunny days!" << endl;
        } else if (season == 4) {
            cout << "Fall - leaves falling!" << endl;
        }
        
    } else {
        // Runs if the input code is completely outside the valid 1-4 range
        cout << "Invalid season code!" << endl;
    }
    
    return 0;
}
